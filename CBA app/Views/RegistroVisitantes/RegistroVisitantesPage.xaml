                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>

                        </Grid.ColumnDefinitions>
                        <Frame Grid.Column="0" HasShadow="True" Padding="-1" CornerRadius="0" BorderColor="Black">
                            <Button  CornerRadius="0" Text="Entrada" BorderColor="LightGray" BorderWidth="0.1" x:Name="tabEntrada" BackgroundColor="{StaticResource Secondary}" TextColor="Black"></Button>

                        </Frame>
                        <Button Grid.Column="1" CornerRadius="0" Text="Salida" BorderColor="LightGray" BorderWidth="0.1" x:Name="tabSalida"></Button>
                        <Button Grid.Column="2" CornerRadius="0" Text="En Predio" BorderColor="LightGray" BorderWidth="0.1" x:Name="tabEnPredio"></Button>
                        <Button Grid.Column="3" CornerRadius="0" Text="Listado" BorderColor="LightGray" BorderWidth="0.1" x:Name="tabListado"></Button>

                    </Grid>
                </StackLayout>-->
           
            
        </Grid>
   
        </VerticalStackLayout>

        
        
    </ScrollView>
       
</ContentPage>