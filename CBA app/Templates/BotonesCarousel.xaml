<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CBA_app.Templates.BotonesCarousel">
    <ScrollView Orientation="Horizontal"
            HorizontalOptions="Fill"
            VerticalOptions="Center" Padding="4" BackgroundColor="#1022b2b5">
        <HorizontalStackLayout BindableLayout.ItemsSource="{Binding Botones}"
                          Spacing="8"
                          
                          VerticalOptions="Center">
            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" CornerRadius="50" Margin="0" WidthRequest="70" HeightRequest="70" HasShadow="True">
                        <Button ImageSource="{Binding Imagen}"
                            Command="{Binding Comando}" 
                            BackgroundColor="Transparent"
                             />
                    </Frame>
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </HorizontalStackLayout>
    </ScrollView>
</ContentView>
