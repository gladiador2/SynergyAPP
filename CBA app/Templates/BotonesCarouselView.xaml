<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CBA_app.Templates.BotonesCarouselView">
    <Grid  HeightRequest="90">
        <CarouselView ItemsSource="{Binding Botones}"
              HorizontalOptions="Fill"
              VerticalOptions="Center"
              HeightRequest="90"
              IndicatorView="indicatorView"
              PeekAreaInsets="150"
              BackgroundColor="#1022b2b5">
            <CarouselView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="0" CornerRadius="50" Margin="0" WidthRequest="70" HeightRequest="70" HasShadow="True">
                        <Button ImageSource="{Binding Imagen}"
                                Command="{Binding Comando}"
                                BackgroundColor="Transparent" />
                    </Frame>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>
        <IndicatorView x:Name="indicatorView"
                       HorizontalOptions="Center"
                       VerticalOptions="End"
                       Margin="0,4,0,0"/>
    </Grid>
</ContentView>
