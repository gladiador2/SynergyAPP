<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:sys="clr-namespace:System;assembly=netstandard"
             x:Class="CBA_app.Templates.FlyoutFooter">
    <VerticalStackLayout>

        <Button  Text="Cerrar Sessión" Command="{Binding SignOutCommand}" Margin="10,0,10,10" >
            <Button.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{StaticResource Tertiary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource Primary}" Offset="1.0" />
                </LinearGradientBrush>
            </Button.Background>
            <Button.Shadow>
                <Shadow Brush="Black" Opacity="0.5" Offset="2,2" Radius="10" />
            </Button.Shadow>
        </Button>
        <HorizontalStackLayout HorizontalOptions="Center">
            <Image Source="cba.png" HeightRequest="20" WidthRequest="20"></Image>
            <Label 
            Text=" CBA SA © "
            FontAttributes="Bold"
            HorizontalOptions="Center" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentView>
