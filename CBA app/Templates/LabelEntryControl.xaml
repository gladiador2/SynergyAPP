<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CBA_app.Templates.LabelEntryControl">
    <VerticalStackLayout>
        <Label Text="{Binding LabelText, Source={x:Reference this}}" />
        <Frame Padding="5,0,5,0">
            <Entry
             Text="{Binding EntryText, Source={x:Reference this}, Mode=TwoWay}"
             Placeholder="{Binding PlaceholderEffective, Source={x:Reference this}}"/>
        </Frame>
    </VerticalStackLayout>
</ContentView>
