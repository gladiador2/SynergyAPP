PORT=3000                  # Puerto en el que se ejecuta el servidor Express
API_KEY=mi_api_key_super_segura_123    # Clave de API para autenticación o acceso a servicios internos
JWT_SECRET=mi_jwt_secreto_ultra_seguro_456  # Secreto usado para firmar y verificar los tokens JWT

PGHOST=localhost           # Host de la base de datos PostgreSQL
PGUSER=postgres            # Usuario de la base de datos PostgreSQL
PGPASSWORD=toor            # Contraseńa del usuario de la base de datos PostgreSQL
PGDATABASE=cbaApp          # Nombre de la base de datos PostgreSQL
PGPORT=5432                # Puerto de conexión a la base de datos PostgreSQL

MAX_INTENTOS=3             # Número máximo de intentos fallidos de login permitidos antes de bloquear temporalmente
VENTANA_MINUTOS=1          # Ventana de tiempo (en minutos) para contar los intentos fallidos de login



