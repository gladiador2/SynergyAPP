{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch JS (app.js)",
      "program": "${workspaceFolder}/app.js",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "runtimeArgs": [
        "--inspect"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch TS (ts-node/esm)",
      "program": "${workspaceFolder}/app.ts",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "runtimeArgs": [
        "--loader",
        "ts-node/esm",
        "--inspect"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ],
      "envFile": "${workspaceFolder}/.env",
      "sourceMaps": true,
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "launch",
      "name": "NPM: dev (nodemon + ts-node)",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "NODE_OPTIONS": "--inspect"
      },
      "envFile": "${workspaceFolder}/.env",
      "autoAttachChildProcesses": true
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach a Node (9229)",
      "port": 9229,
      "restart": true,
      "continueOnAttach": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
